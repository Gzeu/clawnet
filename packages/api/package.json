{
  "name": "@clawnet/api",
  "version": "0.1.0",
  "description": "HTTP and WebSocket API server for ClawNet",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "start": "node dist/index.js",
    "test": "vitest"
  },
  "dependencies": {
    "@clawnet/core": "workspace:*",
    "@clawnet/registry": "workspace:*",
    "@clawnet/message-bus": "workspace:*",
    "@clawnet/memory": "workspace:*",
    "fastify": "^4.26.0",
    "@fastify/websocket": "^10.0.1",
    "@fastify/cors": "^9.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.10",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "license": "MIT"
}