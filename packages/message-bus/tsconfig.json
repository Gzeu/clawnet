{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@clawnet/core": ["../../core/src"],
      "eventemitter3": ["../../../node_modules/eventemitter3"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}