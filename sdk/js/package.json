{
  "name": "@clawnet/sdk",
  "version": "0.1.0",
  "description": "ClawNet SDK for building multi-agent applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest"
  },
  "dependencies": {
    "@clawnet/core": "workspace:*",
    "uuid": "^9.0.0",
    "eventemitter3": "^5.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": ["clawnet", "sdk", "agent", "mesh"],
  "license": "MIT"
}